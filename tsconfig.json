{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"tenbrains": [
				"./packages/core/src/index.ts"
			],
			"@tenbrains/*": [
				"./packages/*/src/index.ts"
			]
		}
	},
	"include": [
		"scripts/**/*.d.mts",
		"scripts/**/*.d.ts",
		"scripts/**/*.ts",
		"packages/*/src/**/*",
		"packages/*/test/**/*"
	],
	"exclude": [
		"**/dist/**"
	]
}
