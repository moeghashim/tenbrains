{
  "name": "tenbrains",
  "version": "2.2.0",
  "description": "Agent-first CLI for X and YouTube research: analyze content, track accounts, surface suggestions, and persist every outcome locally.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeghashim/tenbrains.git"
  },
  "homepage": "https://github.com/moeghashim/tenbrains#readme",
  "bugs": "https://github.com/moeghashim/tenbrains/issues",
  "keywords": [
    "cli",
    "agent",
    "x",
    "twitter",
    "youtube",
    "transcript",
    "research",
    "sqlite",
    "claude"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "tenbrains": "dist/bin/tenbrains.js",
    "tb": "dist/bin/tenbrains.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/bin/tenbrains.js",
    "dev": "tsx src/bin/tenbrains.ts",
    "tenbrains": "tsx src/bin/tenbrains.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run clean && npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  }
}
