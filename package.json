{
	"name": "tenbrains",
	"private": true,
	"license": "MIT",
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev": "npm run -w @tenbrains/web dev",
		"clean": "npm run clean --workspaces --if-present",
		"build": "npm run build --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"check": "biome check --write --error-on-warnings . && node scripts/check-file-length.mjs && tsgo --noEmit",
		"extension:dev": "npm run -w @tenbrains/extension dev",
		"extension:build": "npm run -w @tenbrains/extension build",
		"extension:package": "npm run -w @tenbrains/extension package",
		"extension:test": "npm run -w @tenbrains/extension test",
		"changeset": "changeset",
		"release:status": "changeset status --verbose",
		"release:version": "changeset version",
		"release:publish": "changeset publish",
		"onboarding": "node scripts/onboarding.mjs",
		"xurl:status": "xurl auth status",
		"xurl:whoami": "xurl whoami",
		"xurl:search": "xurl search \"from:XDevelopers\" -n 10",
		"xurl:analyze:auth": "node scripts/configure-openai.mjs",
		"xurl:analyze": "tsx apps/cli/src/analyze-tweet.ts",
		"xurl:takeaway": "tsx apps/cli/src/takeaway.ts",
		"xurl:suggestions": "tsx apps/cli/src/suggestions.ts",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@changesets/cli": "^2.30.0",
		"@types/node": "^22.10.5",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"husky": "^9.1.7",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
