{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "preserve",
		"incremental": true,
		"allowJs": false,
		"noEmit": true,
		"plugins": [{ "name": "next" }],
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"isolatedModules": true,
		"baseUrl": ".",
		"paths": {
			"@tenbrains/ai": ["../../packages/ai/src/index.ts"],
			"@tenbrains/contracts": ["../../packages/contracts/src/index.ts"],
			"@tenbrains/contracts/bookmark-tags": ["../../packages/contracts/src/bookmark-tags.ts"],
			"tenbrains": ["../../packages/core/src/index.ts"],
			"@tenbrains/x-client": ["../../packages/x-client/src/index.ts"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules"]
}
